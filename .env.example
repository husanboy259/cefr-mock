# Copy this file to server/.env and fill in the values

NODE_ENV=development
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://spiko:spiko_password@localhost:5432/spiko_db

# JWT secrets — use long random strings (e.g. openssl rand -hex 32)
JWT_SECRET=change_me_to_a_32_char_secret_key_here
JWT_REFRESH_SECRET=change_me_to_another_32_char_secret

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
